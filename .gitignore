# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
!/build/icon.ico
!/build/icon.icns

# electron-builder output
/dist

# Claude Code workspace
/.claude/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry Config File
.env.sentry-build-plugin

# Android signing (safety net — Capacitor's android/.gitignore covers builds/APKs)
*.jks
*.keystore
keystore.properties
signing.properties
/keystore/
# APKs/AAB generados por Android Studio fuera de android/app/build/
*.apk
*.aab

# Capacitor / Android (regenerable con npx cap add android)
/android

# Recursos de Capacitor (regenerables con npx @capacitor/assets generate)
/resources
